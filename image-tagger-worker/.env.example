# Database (same instance the SvelteKit app/migrations use)
DATABASE_NAME="postgres"
DATABASE_HOST="localhost"
DATABASE_PORT=5432
DATABASE_USER="postgres"
DATABASE_PASSWORD="postgres"

# Blob storage (MinIO). The signed read URL host comes from BLOB_STORAGE_END_POINT,
# so it must be reachable by the image tagger API.
BLOB_STORAGE_END_POINT="localhost"
BLOB_STORAGE_PORT=9000
BLOB_STORAGE_BUCKET="croquis-frontend"
MINIO_ROOT_USER=juhku
MINIO_ROOT_PASSWORD=123456789
MINIO_SSL=

# Image tagger API base URL
IMAGE_TAGGER_API_URL="http://localhost:8000"

# Optional tuning
# SIGNED_URL_EXPIRY_SECONDS=3600
# WORKER_POLL_INTERVAL_MS=2000
# WORKER_BATCH_SIZE=8
