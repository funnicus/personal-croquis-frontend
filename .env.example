FRONTEND_PORT=3000

# MINIO_ROOT_USER length should be at least 3 characters.
MINIO_ROOT_USER=
# MINIO_ROOT_PASSWORD length should be at least 8 characters.
MINIO_ROOT_PASSWORD=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SSL=

BLOB_STORAGE_END_POINT="localhost"
BLOB_STORAGE_PORT=9000
BLOB_STORAGE_API_PORT=9001
BLOB_STORAGE_BUCKET="croquis-frontend"

DATABASE_NAME="postgres"
DATABASE_PORT=5432
DATABASE_HOST="localhost"
DATABASE_USER="postgres"
DATABASE_PASSWORD="postgres"

IMAGE_TAGGER_API_URL="http://localhost:8000"

# Required only when running `docker compose --profile backup ...`.
# Point this at a local folder, preferably one synced by Syncthing.
BACKUP_ARCHIVE_HOST_PATH=/Users/name/Backups/personal-croquis
